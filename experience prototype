<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Airbnb Experience Builder</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --r:#FF385C;--rd:#E00B41;
  --ink:#222222;--mid:#6A6A6A;--soft:#B0B0B0;
  --line:#DDDDDD;--line2:#EBEBEB;
  --sur:#F7F7F7;--wh:#FFFFFF;
  --b:#008A05;--bl:#F0F9F0;
  --amb:#B07000;--ambl:#FBF5E9;
  --rl:#FFF5F7;
  --rsm:8px;--rmd:12px;--rlg:16px;--rpill:999px;
}
body{font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#EDEDED;min-height:100vh;display:flex;align-items:flex-start;justify-content:center;padding:20px;color:var(--ink);}
.sr-only{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);}
#phone{width:380px;background:var(--wh);border-radius:36px;overflow:hidden;border:1px solid var(--line);box-shadow:0 8px 40px rgba(0,0,0,.14);}
.notch{height:26px;display:flex;align-items:center;justify-content:center;background:var(--wh);}
.notch::after{content:'';width:90px;height:5px;background:var(--line);border-radius:var(--rpill);}
.vp{position:relative;overflow:hidden;}

.top{display:flex;align-items:center;justify-content:space-between;padding:11px 18px;border-bottom:1px solid var(--line2);}
.top-l{display:flex;align-items:center;gap:7px;}
.top-w{font-size:14px;font-weight:600;color:var(--r);letter-spacing:-0.2px;}
.av{width:28px;height:28px;border-radius:50%;background:var(--sur);border:1px solid var(--line2);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:var(--mid);}

.prog{display:flex;align-items:center;padding:10px 18px;}
.ps{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--soft);font-weight:500;}
.ps.on{color:var(--ink);}
.ps.done{color:var(--b);}
.pd{width:18px;height:18px;border-radius:50%;border:1.5px solid var(--line);display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:600;background:var(--wh);}
.ps.on .pd{border-color:var(--ink);background:var(--ink);color:#fff;}
.ps.done .pd{border-color:var(--b);background:var(--b);color:#fff;}
.pl{flex:1;height:1.5px;background:var(--line2);margin:0 6px;border-radius:2px;}
.pl.done{background:var(--b);}

.screen{display:none;flex-direction:column;height:580px;}
.screen.on{display:flex;}
.scroll{flex:1;overflow-y:auto;padding:20px 18px 8px;}
.scroll::-webkit-scrollbar{width:0;}
.foot{padding:12px 18px;border-top:1px solid var(--line2);background:var(--wh);flex-shrink:0;}
.btn{background:var(--r);color:#fff;border:none;border-radius:var(--rsm);padding:14px;font-size:15px;font-weight:600;cursor:pointer;width:100%;transition:background .15s;}
.btn:hover{background:var(--rd);}
.btn:disabled{background:var(--line);cursor:not-allowed;}
.back{background:none;border:none;color:var(--ink);font-size:13px;font-weight:500;cursor:pointer;padding:0;display:flex;align-items:center;gap:3px;margin-bottom:16px;}

.eyebrow{font-size:11px;font-weight:600;color:var(--mid);letter-spacing:.3px;margin-bottom:6px;}
.h1{font-size:21px;font-weight:600;line-height:1.25;letter-spacing:-0.4px;margin-bottom:7px;}
.lede{font-size:14px;color:var(--mid);line-height:1.5;margin-bottom:20px;}

.w-h1{font-size:23px;font-weight:600;line-height:1.22;letter-spacing:-0.5px;margin-bottom:8px;}
.w-lede{font-size:13.5px;color:var(--mid);line-height:1.5;margin-bottom:24px;}
.tier-lbl{display:flex;align-items:center;gap:8px;font-size:11px;font-weight:600;color:var(--mid);letter-spacing:.3px;text-transform:uppercase;margin-bottom:11px;}
.tier-lbl .tl-line{flex:1;height:1px;background:var(--line2);}
.tier-sub{font-size:12px;color:var(--soft);font-weight:500;margin:-6px 0 11px;line-height:1.4;}
.pillars-intro{display:grid;grid-template-columns:1fr 1fr;gap:8px 10px;margin-bottom:24px;}
.pillars-intro.further{margin-bottom:8px;}
.pi-item{display:flex;gap:9px;align-items:flex-start;padding:10px;border:1px solid var(--line2);border-radius:var(--rsm);}
.pi-item.further-item{border-color:var(--rl);background:var(--rl);}
.pi-ic{width:18px;height:18px;color:var(--r);flex-shrink:0;margin-top:1px;}
.pi-t{font-size:13px;font-weight:600;margin-bottom:1px;letter-spacing:-0.1px;}
.pi-d{font-size:11.5px;color:var(--mid);line-height:1.35;}
.how-row{display:flex;align-items:center;gap:7px;flex-wrap:wrap;padding:13px;background:var(--sur);border-radius:var(--rmd);}
.how-h{font-size:11px;font-weight:600;color:var(--mid);margin-right:2px;}
.how-step{font-size:12px;font-weight:600;color:var(--ink);}
.how-arr{font-size:12px;color:var(--soft);}
.steps{display:flex;flex-direction:column;}
.step-item{display:flex;gap:14px;padding:14px 0;border-bottom:1px solid var(--line2);}
.step-item:last-child{border-bottom:none;}
.step-n{width:26px;height:26px;border-radius:50%;background:var(--sur);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;color:var(--ink);flex-shrink:0;}
.step-tt{font-size:14px;font-weight:600;margin-bottom:2px;}
.step-dd{font-size:13px;color:var(--mid);line-height:1.4;}

.prompt-q{font-size:15px;font-weight:500;line-height:1.4;margin-bottom:16px;color:var(--ink);}
.input-shell{border:1px solid var(--line);border-radius:var(--rmd);overflow:hidden;transition:border-color .15s;}
.input-shell:focus-within{border-color:var(--ink);}
.input-shell.rec{border-color:var(--r);}
textarea{width:100%;min-height:90px;padding:13px;border:none;font-size:14px;color:var(--ink);resize:none;font-family:inherit;line-height:1.55;outline:none;display:block;}
textarea::placeholder{color:var(--soft);}
.input-bar{display:flex;align-items:center;justify-content:space-between;padding:8px 10px 8px 13px;border-top:1px solid var(--line2);background:var(--sur);}
.input-hint{font-size:12px;color:var(--mid);display:flex;align-items:center;gap:6px;}
.mic{width:36px;height:36px;border-radius:50%;border:none;background:var(--ink);color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px;transition:all .15s;flex-shrink:0;}
.mic:hover{transform:scale(1.05);}
.mic.rec{background:var(--r);animation:pulse 1.1s infinite;}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(255,56,92,.35);}50%{box-shadow:0 0 0 9px rgba(255,56,92,0);}}
.wave{display:flex;align-items:center;gap:2.5px;height:18px;}
.wave span{width:2.5px;background:var(--r);border-radius:2px;display:inline-block;animation:wv .8s infinite;}
.wave span:nth-child(1){height:7px;animation-delay:0s;}.wave span:nth-child(2){height:15px;animation-delay:.1s;}.wave span:nth-child(3){height:10px;animation-delay:.2s;}.wave span:nth-child(4){height:17px;animation-delay:.3s;}.wave span:nth-child(5){height:8px;animation-delay:.15s;}
@keyframes wv{0%,100%{transform:scaleY(1);}50%{transform:scaleY(1.5);}}

.confirm{border:1px solid var(--line);border-radius:var(--rmd);padding:13px;margin-top:13px;display:none;}
.confirm-l{font-size:11px;font-weight:600;color:var(--mid);margin-bottom:8px;}
.confirm-t{font-size:12px;line-height:1.5;color:var(--ink);margin-bottom:13px;}
.confirm-acts{display:flex;gap:8px;}
.cbtn{flex:1;font-size:12px;font-weight:600;padding:10px;border-radius:var(--rsm);border:1px solid var(--line);background:var(--wh);cursor:pointer;color:var(--ink);}
.cbtn.go{background:var(--ink);border-color:var(--ink);color:#fff;}

.chips{display:none;flex-wrap:wrap;gap:7px;margin-top:18px;}
.chips-h{width:100%;font-size:12px;font-weight:600;color:var(--mid);margin-bottom:2px;}
.chip{display:inline-flex;align-items:center;gap:6px;border:1px solid var(--line);border-radius:var(--rpill);padding:7px 13px;font-size:13px;color:var(--ink);background:var(--wh);}
.chip i{font-size:13px;color:var(--mid);}

.convo{display:none;flex-direction:column;gap:18px;margin-top:22px;}
.convo-h{font-size:12px;font-weight:600;color:var(--mid);}
.cq-lbl{font-size:12px;font-weight:600;margin-bottom:7px;color:var(--ink);}
.cq-txt{font-size:14px;line-height:1.45;color:var(--mid);margin-bottom:10px;}
.cq .input-shell textarea{min-height:70px;}
.cbtns{display:flex;gap:8px;justify-content:flex-end;margin-top:8px;}
.nq{font-size:13px;font-weight:600;padding:9px 18px;border-radius:var(--rsm);background:var(--ink);color:#fff;border:none;cursor:pointer;}
.sk{font-size:13px;font-weight:500;padding:9px 16px;border-radius:var(--rsm);background:none;color:var(--mid);border:none;cursor:pointer;}

.detected{display:none;margin-top:22px;}
.det-h{font-size:13px;font-weight:600;margin-bottom:12px;}
.det-card{display:flex;flex-direction:column;gap:6px;border:1px solid var(--line2);border-radius:var(--rmd);padding:12px 13px;margin-bottom:8px;}
.det-tag{font-size:10px;font-weight:600;padding:3px 9px;border-radius:var(--rpill);align-self:flex-start;}
.det-tag.expertise{background:var(--bl);color:var(--b);}
.det-tag.access{background:var(--rl);color:var(--r);}
.det-tag.pov{background:var(--ambl);color:var(--amb);}
.det-txt{font-size:13px;color:var(--ink);line-height:1.45;}
.det-gap{border:1px dashed var(--line);border-radius:var(--rmd);padding:13px;margin-top:14px;background:var(--sur);}
.det-gap-h{font-size:12px;font-weight:600;color:var(--mid);margin-bottom:7px;display:flex;align-items:center;gap:5px;}
.det-gap-h i{color:var(--amb);font-size:14px;}
.det-gap-q{font-size:13px;color:var(--ink);line-height:1.4;margin-bottom:10px;}
.det-gap .input-shell{background:var(--wh);}
.det-gap textarea{min-height:64px;}
.think{display:none;align-items:center;gap:8px;padding:12px 14px;background:var(--sur);border-radius:var(--rmd);font-size:13px;color:var(--mid);margin-top:16px;}
.dots span{display:inline-block;animation:bl 1.2s infinite;}.dots span:nth-child(2){animation-delay:.2s;}.dots span:nth-child(3){animation-delay:.4s;}
@keyframes bl{0%,80%,100%{opacity:.25;}40%{opacity:1;}}

.badge-time{display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:600;color:var(--mid);background:var(--sur);padding:5px 11px;border-radius:var(--rpill);margin-bottom:20px;}
.arow{display:flex;gap:14px;}
.al{display:flex;flex-direction:column;align-items:center;width:28px;flex-shrink:0;}
.anode{width:28px;height:28px;border-radius:50%;border:1.5px solid var(--line);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;background:var(--wh);z-index:1;}
.anode.done{border-color:var(--b);background:var(--b);color:#fff;}
.anode.onn{border-color:var(--ink);}
.anode.pk{border-color:var(--r);background:var(--r);color:#fff;}
.aconn{width:1.5px;flex:1;min-height:16px;background:var(--line);margin:3px 0;}
.aconn.done{background:var(--b);}
.ar{flex:1;padding:1px 0 18px;min-width:0;}
.aslbl{font-size:11px;font-weight:600;color:var(--mid);margin-bottom:3px;}
.ast{font-size:15px;font-weight:600;margin-bottom:6px;letter-spacing:-0.2px;}
.asd{font-size:13px;color:var(--mid);line-height:1.5;}
.hv{font-size:13px;line-height:1.45;color:var(--ink);padding:9px 12px;background:var(--sur);border-radius:var(--rsm);margin:6px 0 8px;border-left:2px solid var(--ink);}
.peak-box{border:1px solid var(--r);border-radius:var(--rmd);padding:13px;background:var(--rl);}
.peak-eye{font-size:11px;font-weight:600;color:var(--r);margin-bottom:5px;display:flex;align-items:center;gap:4px;}
.peak-t{font-size:15px;font-weight:600;margin-bottom:7px;letter-spacing:-0.2px;}
.peak-d{font-size:13px;color:var(--mid);line-height:1.5;}
.stops{display:flex;flex-direction:column;gap:7px;margin:6px 0 9px;}
.stop{display:flex;gap:10px;padding:11px 12px;background:var(--wh);border:1px solid var(--line2);border-radius:var(--rsm);}
.snum{width:20px;height:20px;border-radius:50%;background:var(--sur);color:var(--mid);font-size:11px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;}
.sn{font-size:13px;font-weight:600;margin-bottom:2px;}
.sd2{font-size:12px;color:var(--mid);line-height:1.4;}
.add-stop{display:flex;align-items:center;justify-content:center;gap:6px;padding:10px;border:1px dashed var(--line);border-radius:var(--rsm);background:none;font-size:13px;font-weight:500;color:var(--mid);cursor:pointer;width:100%;}
.add-stop:hover{border-color:var(--ink);color:var(--ink);}
.note{display:flex;gap:9px;padding:12px;border-radius:var(--rmd);margin-top:9px;font-size:13px;line-height:1.45;}
.note.ok{background:var(--bl);}
.note.warn{background:var(--ambl);}
.note-link{background:none;border:none;color:var(--amb);font-size:13px;font-weight:600;cursor:pointer;padding:0;text-decoration:underline;font-family:inherit;}
.more-btn{display:inline-flex;align-items:center;gap:5px;background:none;border:none;color:var(--mid);font-size:12px;font-weight:600;cursor:pointer;padding:0;margin-top:10px;font-family:inherit;}
.more-btn:hover{color:var(--ink);}
.more-btn span{font-size:14px;}
.more-tip{display:none;font-size:12px;color:var(--ink);line-height:1.55;margin-top:8px;padding:10px 12px;background:var(--bl);border-radius:var(--rsm);border-left:2px solid var(--b);}
.more-tip.show{display:block;}
.note i{flex-shrink:0;margin-top:1px;}
.note.ok i{color:var(--b);}.note.warn i{color:var(--amb);}


.cult{display:flex;gap:11px;align-items:flex-start;padding:13px;background:var(--sur);border-radius:var(--rmd);margin-bottom:18px;}
.cult-fl{font-size:20px;flex-shrink:0;line-height:1.2;}
.cult-n{font-size:13px;font-weight:600;margin-bottom:3px;}
.cult-i{font-size:12px;color:var(--mid);line-height:1.45;}

.pillars{display:flex;flex-direction:column;gap:8px;}
.sc-tier{display:flex;align-items:center;gap:8px;font-size:11px;font-weight:600;color:var(--mid);letter-spacing:.3px;text-transform:uppercase;margin:18px 0 4px;}
.sc-tier:first-child{margin-top:0;}
.sc-tier .tl-line{flex:1;height:1px;background:var(--line2);}
.pc{border:1px solid var(--line2);border-radius:var(--rmd);padding:14px;cursor:pointer;transition:border-color .15s;}
.pc.open{border-color:var(--ink);}
.pc-h{display:flex;align-items:center;justify-content:space-between;}
.pc-n{font-size:14px;font-weight:600;}
.badge{font-size:11px;font-weight:600;padding:3px 9px;border-radius:var(--rpill);}
.badge.ok{background:var(--bl);color:var(--b);}.badge.warn{background:var(--ambl);color:var(--amb);}.badge.flag{background:var(--rl);color:var(--r);}
.pc-q{font-size:12px;color:var(--mid);line-height:1.4;margin-top:5px;}
.pc-d{display:none;font-size:13px;line-height:1.5;color:var(--ink);border-top:1px solid var(--line2);padding-top:11px;margin-top:11px;}
.pc.open .pc-d{display:block;}
.pc-cult{font-size:12px;color:var(--b);margin-top:9px;padding:8px 10px;background:var(--bl);border-radius:var(--rsm);line-height:1.45;}
.pc-sug{font-size:12px;line-height:1.5;margin-top:9px;padding:9px 11px;background:var(--sur);border-radius:var(--rsm);}
.pc-sug strong{color:var(--ink);}

.m-card{border:1px solid var(--line2);border-radius:var(--rmd);padding:14px;margin-bottom:10px;transition:all .2s;}
.m-card.hl{border-color:var(--r);box-shadow:0 0 0 3px var(--rl);}
.m-card.added{border-color:var(--b);background:var(--bl);}
.m-top{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:7px;}
.mw{font-size:11px;font-weight:600;color:var(--mid);}
.mtag{font-size:11px;font-weight:600;padding:3px 9px;border-radius:var(--rpill);display:inline-block;flex-shrink:0;}
.mtag.conn{background:var(--bl);color:var(--b);}.mtag.part{background:var(--sur);color:var(--mid);}.mtag.peak{background:var(--rl);color:var(--r);}.mtag.earn{background:var(--ambl);color:var(--amb);}
.mt{font-size:14px;font-weight:600;margin-bottom:5px;letter-spacing:-0.2px;}
.md{font-size:13px;color:var(--mid);line-height:1.5;margin-bottom:12px;}
.am{font-size:13px;font-weight:600;padding:10px;border-radius:var(--rsm);border:1px solid var(--ink);background:var(--wh);cursor:pointer;color:var(--ink);width:100%;transition:all .15s;}
.am:hover{background:var(--ink);color:#fff;}
.am.added{border-color:var(--b);color:var(--b);background:var(--bl);cursor:default;}
.am.added:hover{background:var(--bl);color:var(--b);}

.evolve{border:1px solid var(--line2);border-radius:var(--rmd);padding:16px;margin-top:20px;}
.ev-t{font-size:14px;font-weight:600;margin-bottom:5px;letter-spacing:-0.2px;}
.ev-s{font-size:12px;color:var(--mid);line-height:1.45;margin-bottom:14px;}
.ev-flow{display:flex;flex-direction:column;gap:8px;margin-bottom:14px;}
.ev-step{display:flex;align-items:center;gap:10px;font-size:12px;color:var(--ink);}
.ev-dot{width:22px;height:22px;border-radius:50%;background:var(--sur);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;color:var(--mid);flex-shrink:0;}
.ev-stat{background:var(--sur);border-radius:var(--rsm);padding:11px 13px;font-size:12px;line-height:1.5;color:var(--ink);}
.ev-stat strong{color:var(--r);}
.tog-row{display:flex;align-items:center;justify-content:space-between;padding:15px 0 2px;margin-top:4px;border-top:1px solid var(--line2);}
.tog-i{font-size:13px;}.tog-i small{display:block;font-size:11px;color:var(--mid);margin-top:2px;}
.tog{position:relative;width:40px;height:23px;border-radius:var(--rpill);background:var(--b);border:none;cursor:pointer;flex-shrink:0;transition:background .15s;}
.tog::after{content:'';position:absolute;top:3px;left:3px;width:17px;height:17px;border-radius:50%;background:#fff;transition:transform .15s;}
.tog.off{background:var(--line);}.tog:not(.off)::after{transform:translateX(17px);}

.ov{display:none;position:absolute;inset:0;background:rgba(0,0,0,.4);z-index:50;align-items:flex-end;}
.ov.show{display:flex;}
.sheet{background:var(--wh);border-radius:18px 18px 0 0;width:100%;max-height:88%;overflow-y:auto;padding:18px;}
.grab{width:34px;height:4px;background:var(--line);border-radius:var(--rpill);margin:0 auto 16px;}
.sheet-t{font-size:16px;font-weight:600;margin-bottom:3px;letter-spacing:-0.3px;}
.sheet-m{font-size:12px;color:var(--mid);margin-bottom:18px;}
.sheet-sec{margin-bottom:16px;}
.sheet-sl{font-size:11px;font-weight:600;color:var(--mid);margin-bottom:9px;}
.bp-ar{display:flex;gap:9px;margin-bottom:8px;}
.bp-ad{width:22px;height:22px;border-radius:50%;background:var(--b);color:#fff;font-size:10px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.bp-ad.pk{background:var(--r);}
.bp-at{font-size:12px;line-height:1.5;flex:1;}
.bp-fl{font-size:12px;padding:8px 11px;border-radius:var(--rsm);margin-bottom:6px;line-height:1.45;}
.bp-fl.ok{background:var(--bl);}.bp-fl.warn{background:var(--ambl);}.bp-fl.flag{background:var(--rl);}

/* blueprint tabs */
.bp-tabs{display:flex;gap:4px;background:var(--sur);border-radius:var(--rsm);padding:3px;margin-bottom:18px;}
.bp-tab{flex:1;text-align:center;font-size:12px;font-weight:600;padding:8px;border-radius:6px;cursor:pointer;color:var(--mid);border:none;background:none;transition:all .15s;}
.bp-tab.active{background:var(--wh);color:var(--ink);box-shadow:0 1px 2px rgba(0,0,0,.08);}
.bp-view{display:none;}
.bp-view.active{display:block;}

/* listing preview */
.lst-hero{height:120px;border-radius:var(--rmd);background:linear-gradient(135deg,#FF385C 0%,#FF7A8A 55%,#FFB400 130%);position:relative;overflow:hidden;margin-bottom:14px;display:flex;align-items:flex-end;padding:12px;}
.lst-hero-badge{font-size:10px;font-weight:600;color:#fff;background:rgba(0,0,0,.22);padding:4px 9px;border-radius:var(--rpill);backdrop-filter:blur(4px);}
.lst-hero-ic{position:absolute;top:12px;right:12px;font-size:18px;color:rgba(255,255,255,.85);}
.lst-title{font-size:18px;font-weight:600;line-height:1.25;letter-spacing:-0.3px;margin-bottom:8px;}
.lst-meta{display:flex;align-items:center;gap:10px;font-size:13px;color:var(--ink);margin-bottom:14px;flex-wrap:wrap;}
.lst-meta .dot{color:var(--soft);}
.lst-rate{display:flex;align-items:center;gap:3px;font-weight:600;}
.lst-rate i{color:var(--ink);font-size:13px;}
.lst-host{display:flex;align-items:center;gap:10px;padding:12px 0;border-top:1px solid var(--line2);border-bottom:1px solid var(--line2);margin-bottom:14px;}
.lst-host-av{width:38px;height:38px;border-radius:50%;background:var(--r);color:#fff;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;flex-shrink:0;}
.lst-host-n{font-size:13px;font-weight:600;}
.lst-host-d{font-size:12px;color:var(--mid);}
.lst-sec-t{font-size:14px;font-weight:600;margin-bottom:10px;letter-spacing:-0.2px;}
.lst-do{display:flex;flex-direction:column;gap:11px;margin-bottom:16px;}
.lst-do-item{display:flex;gap:11px;}
.lst-do-ic{width:26px;height:26px;border-radius:50%;background:var(--sur);display:flex;align-items:center;justify-content:center;font-size:13px;color:var(--ink);flex-shrink:0;}
.lst-do-ic.pk{background:var(--rl);color:var(--r);}
.lst-do-t{font-size:13px;font-weight:600;margin-bottom:2px;}
.lst-do-d{font-size:12px;color:var(--mid);line-height:1.4;}
.lst-inc{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:8px;}
.lst-inc-i{display:inline-flex;align-items:center;gap:5px;font-size:12px;color:var(--ink);background:var(--sur);padding:6px 11px;border-radius:var(--rpill);}
.lst-inc-i i{font-size:13px;color:var(--mid);}
.lst-note{font-size:11px;color:var(--soft);text-align:center;margin-top:14px;font-style:italic;}
.submit-note{font-size:12px;color:var(--mid);line-height:1.5;background:var(--sur);border-radius:var(--rsm);padding:11px 13px;margin-bottom:10px;}
.confirmed{display:none;text-align:center;padding:14px 8px 4px;}
.confirmed-ic{font-size:46px;color:var(--b);line-height:1;margin-bottom:12px;}
.confirmed-t{font-size:18px;font-weight:600;margin-bottom:8px;letter-spacing:-0.3px;}
.confirmed-d{font-size:13px;color:var(--mid);line-height:1.5;}

/* Carousel examples */
.pq-carousel{border:1px solid var(--line2);border-radius:var(--rmd);overflow:hidden;margin-bottom:10px;}
.pqc-slide{display:none;font-size:12px;color:var(--mid);line-height:1.5;padding:11px 13px;font-style:italic;}
.pqc-slide.on{display:block;}
.pqc-footer{display:flex;align-items:center;justify-content:space-between;padding:7px 10px;border-top:1px solid var(--line2);background:var(--sur);}
.pqc-dots{display:flex;gap:5px;align-items:center;}
.pqc-dot{width:5px;height:5px;border-radius:50%;background:var(--line);transition:background .15s;}
.pqc-dot.on{background:var(--ink);}
.pqc-arrows{display:flex;gap:4px;}
.pqc-arr{width:26px;height:26px;border-radius:50%;border:1px solid var(--line);background:var(--wh);cursor:pointer;font-size:13px;color:var(--ink);display:flex;align-items:center;justify-content:center;transition:all .15s;font-family:inherit;}
.pqc-arr:hover{border-color:var(--ink);background:var(--ink);color:#fff;}
.pq-wrap{display:flex;flex-direction:column;gap:0;}
.pq-block{border:1px solid var(--line2);border-radius:var(--rlg);padding:16px;margin-bottom:12px;transition:border-color .2s,background .2s;display:none;}
.pq-block.pq-active{display:block;}
.pq-block.pq-complete{display:block;border-color:var(--b);background:var(--bl);}
.pq-num{font-size:10px;font-weight:700;color:var(--r);letter-spacing:.6px;text-transform:uppercase;margin-bottom:4px;}
.pq-label{font-size:15px;font-weight:600;line-height:1.3;letter-spacing:-0.2px;margin-bottom:5px;}
.pq-sub{font-size:13px;color:var(--mid);line-height:1.5;margin-bottom:14px;}
/* examples toggle */
.pq-ex-toggle{display:inline-flex;align-items:center;gap:5px;background:none;border:none;font-size:12px;font-weight:600;color:var(--r);cursor:pointer;padding:0;font-family:inherit;margin-bottom:12px;}
.pq-ex-toggle svg{transition:transform .2s;}
.pq-ex-toggle.open svg{transform:rotate(180deg);}
.pq-examples{display:none;flex-direction:column;gap:6px;margin-bottom:12px;}
.pq-examples.show{display:flex;}
.pqe-label{font-size:10px;font-weight:600;color:var(--soft);letter-spacing:.3px;text-transform:uppercase;margin-bottom:4px;}
.pqe{text-align:left;background:var(--wh);border:1px solid var(--line2);border-radius:var(--rsm);padding:9px 12px;font-size:12px;color:var(--mid);cursor:pointer;line-height:1.4;font-family:inherit;transition:all .15s;}
.pqe:hover{border-color:var(--r);color:var(--ink);}
/* input area */
.pq-shell{border:1px solid var(--line);border-radius:var(--rmd);overflow:hidden;transition:border-color .15s;margin-bottom:0;}
.pq-shell:focus-within{border-color:var(--ink);}
.pq-shell.rec{border-color:var(--r);}
.pq-ta{width:100%;min-height:80px;padding:12px 13px;border:none;font-size:13px;color:var(--ink);resize:none;font-family:inherit;line-height:1.55;outline:none;display:block;}
.pq-ta::placeholder{color:var(--soft);}
.pq-bar{display:flex;align-items:center;justify-content:space-between;padding:7px 9px 7px 12px;border-top:1px solid var(--line2);background:var(--sur);}
.pq-hint{font-size:11px;color:var(--mid);display:flex;align-items:center;gap:5px;}
.pq-mic{width:30px;height:30px;border-radius:50%;border:none;background:var(--ink);color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;flex-shrink:0;}
.pq-mic:hover{transform:scale(1.07);}
.pq-mic.rec{background:var(--r);animation:pulse 1.1s infinite;}
.pq-next{background:var(--ink);color:#fff;border:none;border-radius:var(--rsm);padding:11px 14px;font-size:13px;font-weight:600;cursor:pointer;width:100%;margin-top:10px;transition:background .15s;font-family:inherit;}
.pq-next:hover{background:#111;}
/* done state */
.pq-done{display:none;align-items:flex-start;justify-content:space-between;gap:10px;}
.pq-done.show{display:flex;}
.pq-done-text{font-size:13px;color:var(--ink);line-height:1.5;flex:1;}
.pq-edit{font-size:12px;font-weight:600;color:var(--b);background:none;border:none;cursor:pointer;padding:0;font-family:inherit;flex-shrink:0;text-decoration:underline;white-space:nowrap;}
</style>
</head>
