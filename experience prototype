          <div class="confirmed-ic"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;vertical-align:middle;"><path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"/><path d="M9 12l2 2l4 -4"/></svg></div>
          <div class="confirmed-t">Submitted for review</div>
          <div class="confirmed-d">Your experience is with the Airbnb Experiences team. They'll check it against the quality standard and get back to you within 3–5 days.</div>
          <button class="btn" onclick="finishAndHome()" style="margin-top:18px;">Done</button>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
var added=[],stopCount=3,isRec=false;
var qAnswers={1:'',2:'',3:''};
var qDone={1:false,2:false,3:false};

function go(n){
  document.querySelectorAll('.screen').forEach(function(s){s.classList.remove('on');});
  document.getElementById('s'+n).classList.add('on');
  var pn=n>=3?3:(n===0?1:n);
  [1,2,3].forEach(function(i){
    var p=document.getElementById('ps'+i);
    p.classList.remove('on','done');
    if(i===pn)p.classList.add('on');
    else if(i<pn)p.classList.add('done');
  });
  [1,2].forEach(function(i){
    var l=document.getElementById('pl'+i);
    l.classList.remove('done');
    if(i<pn)l.classList.add('done');
  });
  var sc=document.querySelector('#s'+n+' .scroll');
  if(sc)sc.scrollTop=0;
}

// Voice samples per question
var qSamples={
  1:"A 3-hour food tour through Tsukiji outer market — I take small groups through the stalls, we eat with vendors, and end with sake in a shop that has no English sign.",
  2:"I've shopped this market for 20 years. I know every vendor by name — Yamamoto keeps the best cuts back for my group. This is not something you can find on Google.",
  3:"I'm designing for curious travelers who want to feel like a local for a few hours — not someone who watched a travel show, but someone who actually lives here."
};
var micSvgStr='<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 2m0 3a3 3 0 0 1 3-3a3 3 0 0 1 3 3v5a3 3 0 0 1-3 3a3 3 0 0 1-3-3z"/><path d="M5 10a7 7 0 0 0 14 0"/><path d="M8 21l8 0"/><path d="M12 17l0 4"/></svg>';
var waveSvgStr='<div class="wave"><span></span><span></span><span></span><span></span><span></span></div>';

// Toggle examples disclosure
function toggleEx(n){
  var ex=document.getElementById('pq'+n+'-ex');
  var btn=document.getElementById('pq'+n+'-ext');
  var open=ex.classList.toggle('show');
  btn.classList.toggle('open',open);
  btn.lastChild.textContent=open?' Hide example':' See an example';
}

// Carousel step — no prefill, just browse
var exIdx={1:0,2:0,3:0};
function stepEx(n,dir){
  var slides=document.querySelectorAll('#pq'+n+'-track .pqc-slide');
  var dots=document.querySelectorAll('#pq'+n+'-dots .pqc-dot');
  var total=slides.length;
  slides[exIdx[n]].classList.remove('on');
  dots[exIdx[n]].classList.remove('on');
  exIdx[n]=(exIdx[n]+dir+total)%total;
  slides[exIdx[n]].classList.add('on');
  dots[exIdx[n]].classList.add('on');
}

// Show/hide Next button as user types
function onQInput(n){
  var val=document.getElementById('pq'+n+'-ta').value.trim();
  document.getElementById('pq'+n+'-next').style.display=val.length>10?'block':'none';
}

// Per-question voice mic
function micQ(n){
  var isRec=document.getElementById('pq'+n+'-mic').classList.contains('rec');
  var mic=document.getElementById('pq'+n+'-mic');
  var hint=document.getElementById('pq'+n+'-hint');
  var shell=document.getElementById('pq'+n+'-shell');
  if(!isRec){
    mic.classList.add('rec');
    shell.classList.add('rec');
    hint.innerHTML=waveSvgStr+' Listening\u2026';
    setTimeout(function(){
      if(!mic.classList.contains('rec'))return;
      mic.classList.remove('rec');
      shell.classList.remove('rec');
      hint.innerHTML=micSvgStr+' Tap to speak';
      document.getElementById('pq'+n+'-ta').value=qSamples[n];
      onQInput(n);
    },2400);
  } else {
    mic.classList.remove('rec');
    shell.classList.remove('rec');
    hint.innerHTML=micSvgStr+' Tap to speak';
  }
}

// Commit answer, collapse, surface next
function commitQ(n){
  var val=document.getElementById('pq'+n+'-ta').value.trim();
  if(!val)return;
  qAnswers[n]=val;
  var block=document.getElementById('pq'+n);
  // hide input elements
  block.querySelector('.pq-sub').style.display='none';
  block.querySelector('.pq-ex-toggle').style.display='none';
  var ex=document.getElementById('pq'+n+'-ex');
  if(ex)ex.style.display='none';
  block.querySelector('.pq-shell').style.display='none';
  block.querySelector('#pq'+n+'-next').style.display='none';
  // show done state
  block.classList.add('pq-complete');
  document.getElementById('pq'+n+'-val').textContent=val;
  document.getElementById('pq'+n+'-done').classList.add('show');

  if(n<3){
    setTimeout(function(){
      var next=document.getElementById('pq'+(n+1));
      next.classList.add('pq-active');
      next.scrollIntoView({behavior:'smooth',block:'nearest'});
    },220);
  } else {
    setTimeout(function(){
      var det=document.getElementById('detected');
      det.style.display='block';
      det.scrollIntoView({behavior:'smooth',block:'start'});
      document.getElementById('buildBtn').disabled=false;
    },320);
  }
}

// Edit a committed question — re-open it and re-lock subsequent ones
function editQ(n){
  var block=document.getElementById('pq'+n);
  block.querySelector('.pq-sub').style.display='';
  block.querySelector('.pq-ex-toggle').style.display='';
  block.querySelector('.pq-shell').style.display='';
  block.querySelector('#pq'+n+'-next').style.display='none';
  block.classList.remove('pq-complete');
  document.getElementById('pq'+n+'-done').classList.remove('show');
  qAnswers[n]='';
  for(var i=n+1;i<=3;i++){
    var b=document.getElementById('pq'+i);
    b.classList.remove('pq-active','pq-complete');
    b.querySelector('.pq-sub').style.display='';
    b.querySelector('.pq-ex-toggle').style.display='';
    b.querySelector('.pq-shell').style.display='';
    document.getElementById('pq'+i+'-done').classList.remove('show');
    document.getElementById('pq'+i+'-next').style.display='none';
    document.getElementById('pq'+i+'-ta').value='';
    qAnswers[i]='';
  }
  document.getElementById('detected').style.display='none';
  document.getElementById('buildBtn').disabled=true;
  document.getElementById('pq'+n+'-ta').focus();
}

function build(){
  var b=document.getElementById('buildBtn'),t=document.getElementById('think');
  b.disabled=true;b.textContent='Building…';t.style.display='flex';
  setTimeout(function(){t.style.display='none';b.textContent='Build my arc';go(2);},1600);
}

function addStop(){
  stopCount++;
  var l=document.getElementById('stops'),d=document.createElement('div');
  d.className='stop';
  d.innerHTML='<div class="snum">'+stopCount+'</div><div style="flex:1;"><div class="sn" contenteditable="true" style="outline:none;border-bottom:1px dashed var(--line);">New stop</div><div class="sd2" contenteditable="true" style="outline:none;margin-top:3px;">What happens here, and why it matters?</div></div>';
  l.appendChild(d);
  document.getElementById('durLbl').textContent='3 hours · '+stopCount+' stops';
  d.querySelector('[contenteditable]').focus();
}

function tog(id){
  var el=document.getElementById('p-'+id),o=el.classList.contains('open');
  document.querySelectorAll('.pc').forEach(function(c){c.classList.remove('open');});
  if(!o){el.classList.add('open');el.scrollIntoView({behavior:'smooth',block:'nearest'});}
}

function addM(id){
  var c=document.getElementById(id),b=document.getElementById(id+'b');
  c.classList.add('added');b.classList.add('added');b.textContent='✓ Added';b.onclick=null;
  if(added.indexOf(id)<0)added.push(id);
}

function goToMoment(){go(4);setTimeout(function(){var m=document.getElementById('m1');if(m){m.scrollIntoView({behavior:'smooth',block:'center'});m.classList.add('hl');setTimeout(function(){m.classList.remove('hl');},2200);}},120);}

function moreTip(e,id){e.stopPropagation();var t=document.getElementById('tip-'+id),ar=document.getElementById('ar-'+id);var open=t.classList.toggle('show');ar.textContent=open?'–':'+';}

function openBp(){
  var names={m1:'Food memory question (participation)',m2:'Guest chooses ingredient (participation)',m3:'Sake brewer reveal (peak)',m4:'Guests cook it themselves (earned reward)'};
  if(added.length)document.getElementById('bpM').innerHTML=added.map(function(id){return '✓ '+names[id];}).join('<br>');
  document.getElementById('ov').classList.add('show');
}

function closeBp(e){
  if(!e||e.target===document.getElementById('ov')){
    document.getElementById('ov').classList.remove('show');
    setTimeout(resetSheet,300);
  }
}

function submitExp(){
  document.querySelector('.bp-tabs').style.display='none';
  document.getElementById('view-bp').classList.remove('active');
  document.getElementById('view-lst').classList.remove('active');
  document.getElementById('submitNote').style.display='none';
  document.getElementById('submitBtn').style.display='none';
  document.getElementById('sheetT').style.display='none';
  document.getElementById('sheetM').style.display='none';
  document.getElementById('confirmed').style.display='block';
  var sh=document.querySelector('.sheet');if(sh)sh.scrollTop=0;
}

function finishAndHome(){document.getElementById('ov').classList.remove('show');setTimeout(function(){resetSheet();go(0);},300);}

function resetSheet(){
  document.querySelector('.bp-tabs').style.display='flex';
  document.getElementById('submitNote').style.display='block';
  document.getElementById('submitBtn').style.display='block';
  document.getElementById('sheetT').style.display='block';
  document.getElementById('sheetM').style.display='block';
  document.getElementById('confirmed').style.display='none';
  switchTab('bp');
}

function switchTab(t){
  document.getElementById('tab-bp').classList.toggle('active',t==='bp');
  document.getElementById('tab-lst').classList.toggle('active',t==='lst');
  document.getElementById('view-bp').classList.toggle('active',t==='bp');
  document.getElementById('view-lst').classList.toggle('active',t==='lst');
  var sh=document.querySelector('.sheet');if(sh)sh.scrollTop=0;
}
</script>
</body>
</html>
