        </div><!-- /pq-wrap -->

        <!-- Analysis reveal (after all 3) -->
        <div class="detected" id="detected" style="margin-top:4px;">
          <div class="det-h">Here's what makes this irreplaceable</div>
          <div class="det-card">
            <div class="det-tag expertise">Expertise</div>
